{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "build-attestation.ts",
    "canonicalize.ts",
    "hash.ts",
    "merkle.ts",
    "sign-attestation.ts",
    "verify-attestation.ts",
    "verify-chain.ts",
    "types/**/*.ts",
    "schemas/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "__tests__", "examples", "vitest.config.ts"]
}
